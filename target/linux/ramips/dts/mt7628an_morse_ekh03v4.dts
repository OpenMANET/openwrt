#include "mt7628an_morse_ekh03.dtsi"
#include "mt7628an_morse_ekh03_rgbled.dtsi"

/ {
	compatible = "morse,ekh03v4", "mediatek,mt7628an-soc";
	// Hotplug script will add a version here (currently -05US),
	// so we leave this without a v4.
	model = "MorseMicro EKH03";
};

&firmware {
	reg = <0x50000 0x1fb0000>;
};

&state_default {
	gpio {
		groups = "wled_an", "refclk", "wdt", "pwm0", "pwm1", "uart2";
		function = "gpio";
	};
};

&uart2_pins {
	uart2 {
		groups = "uart2";
		function = "gpio";
	};
};

&pwm0_pins {
	pwm0 {
		groups = "pwm0";
		function = "gpio";
	};
};

&pwm1_pins {
	pwm1 {
		groups = "pwm1";
		function = "gpio";
	};
};
